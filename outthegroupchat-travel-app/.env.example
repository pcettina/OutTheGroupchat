# ============================================================
# OutTheGroupchat — Environment Variables Reference
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local or any file containing real secrets.
# ============================================================

# ─── Database (Supabase PostgreSQL) ─────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# ─── NextAuth ───────────────────────────────────────────────
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"

# ─── OpenAI ─────────────────────────────────────────────────
OPENAI_API_KEY="sk-..."

# ─── Email (Resend) ─────────────────────────────────────────
RESEND_API_KEY="re_..."
EMAIL_FROM="onboarding@yourdomain.com"

# ─── Real-Time (Pusher) ─────────────────────────────────────
# Get these from https://pusher.com — create an app in the dashboard.
PUSHER_APP_ID="your-app-id"
PUSHER_KEY="your-key"
PUSHER_SECRET="your-secret"
PUSHER_CLUSTER="us2"
# Public vars exposed to the browser
NEXT_PUBLIC_PUSHER_KEY="your-key"
NEXT_PUBLIC_PUSHER_CLUSTER="us2"

# ─── Rate Limiting (Upstash Redis) ──────────────────────────
UPSTASH_REDIS_REST_URL="https://your-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-token"

# ─── Error Monitoring (Sentry) ──────────────────────────────
# Get DSN from https://sentry.io — create a Next.js project.
SENTRY_DSN="https://your-key@oXXXXXX.ingest.sentry.io/XXXXXXX"
SENTRY_ORG="your-org"
SENTRY_PROJECT="your-project"
# Auth token for source map uploads (CI/Vercel only)
SENTRY_AUTH_TOKEN="sntryu_..."

# ─── Image Search (Unsplash) ────────────────────────────────
UNSPLASH_ACCESS_KEY="your-access-key"

# ─── Place Discovery (OpenTripMap) ──────────────────────────
# Required by /api/discover/import. Get a free key at https://opentripmap.io/product
OPENTRIPMAP_API_KEY="your-opentripmap-key"

# ─── Automation / Webhooks (n8n) ────────────────────────────
# Required by /api/newsletter/subscribe and /api/beta/initialize-password.
# Set this to the API key configured in your n8n instance.
N8N_API_KEY="your-n8n-api-key"

# ─── Demo Mode ──────────────────────────────────────────────
# Set to "true" to enable the /api/auth/demo endpoint. Required — without this,
# demo login is disabled regardless of other demo vars.
DEMO_MODE="false"
# Email and password for the demo account (used when DEMO_MODE=true).
DEMO_USER_EMAIL="demo@example.com"
DEMO_USER_PASSWORD="change-me"

# ─── Cron Jobs ──────────────────────────────────────────────
# Must match the Authorization: Bearer header in vercel.json cron config.
CRON_SECRET="generate-with: openssl rand -base64 32"
