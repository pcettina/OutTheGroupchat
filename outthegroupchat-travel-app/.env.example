# ============================================================
# OutTheGroupchat — Environment Variables Reference
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local or any file containing real secrets.
# ============================================================

# ─── Database (Supabase PostgreSQL) ─────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# ─── NextAuth ───────────────────────────────────────────────
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"

# ─── Google OAuth ────────────────────────────────────────────
# Required for Google social login via NextAuth.
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ─── AI Providers ───────────────────────────────────────────
# OpenAI — primary provider for AI trip planning and chat features.
OPENAI_API_KEY="sk-..."
# Anthropic — optional alternative AI provider (used when OPENAI_API_KEY is absent).
ANTHROPIC_API_KEY="sk-ant-..."

# ─── Email (Resend) ─────────────────────────────────────────
RESEND_API_KEY="re_..."
EMAIL_FROM="onboarding@yourdomain.com"

# ─── Real-Time (Pusher) ─────────────────────────────────────
# Get these from https://pusher.com — create an app in the dashboard.
PUSHER_APP_ID="your-app-id"
PUSHER_KEY="your-key"
PUSHER_SECRET="your-secret"
PUSHER_CLUSTER="us2"
# Public vars exposed to the browser
NEXT_PUBLIC_PUSHER_KEY="your-key"
NEXT_PUBLIC_PUSHER_CLUSTER="us2"

# ─── Rate Limiting (Upstash Redis) ──────────────────────────
UPSTASH_REDIS_REST_URL="https://your-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-token"

# ─── Error Monitoring (Sentry) ──────────────────────────────
# Get DSN from https://sentry.io — create a Next.js project.
SENTRY_DSN="https://your-key@oXXXXXX.ingest.sentry.io/XXXXXXX"
SENTRY_ORG="your-org"
SENTRY_PROJECT="your-project"
# Auth token for source map uploads (CI/Vercel only)
SENTRY_AUTH_TOKEN="sntryu_..."

# ─── Image Search (Unsplash) ────────────────────────────────
UNSPLASH_ACCESS_KEY="your-access-key"

# ─── Place Discovery (OpenTripMap) ──────────────────────────
# Required by /api/discover/import. Get a free key at https://opentripmap.io/product
OPENTRIPMAP_API_KEY="your-opentripmap-key"

# ─── Places Autocomplete (Google Places) ────────────────────
# Required for destination autocomplete and place details.
# Enable the Places API at https://console.cloud.google.com/apis/library
GOOGLE_PLACES_API_KEY="your-google-places-api-key"

# ─── Flight Search (Amadeus) ────────────────────────────────
# Required for live flight search. Get credentials at https://developers.amadeus.com
AMADEUS_API_KEY="your-amadeus-api-key"
AMADEUS_API_SECRET="your-amadeus-api-secret"

# ─── Events (Ticketmaster) ──────────────────────────────────
# Required for local events search. Get a key at https://developer.ticketmaster.com
TICKETMASTER_API_KEY="your-ticketmaster-api-key"

# ─── Automation / Webhooks (n8n) ────────────────────────────
# Required by /api/newsletter/subscribe and /api/beta/initialize-password.
# Set this to the API key configured in your n8n instance.
N8N_API_KEY="your-n8n-api-key"

# ─── Logging ────────────────────────────────────────────────
# Controls pino log verbosity. Defaults: "info" in production, "debug" in development, "silent" in test.
# Valid values: trace | debug | info | warn | error | fatal | silent
LOG_LEVEL="debug"

# ─── Demo Mode ──────────────────────────────────────────────
# Set to true to enable the demo login endpoint at /api/auth/demo (development only)
DEMO_MODE=false
# Email and password for the demo account (used when DEMO_MODE=true).
DEMO_USER_EMAIL="demo@example.com"
DEMO_USER_PASSWORD="change-me"

# ─── Cron Jobs ──────────────────────────────────────────────
# Must match the Authorization: Bearer header in vercel.json cron config.
CRON_SECRET="generate-with: openssl rand -base64 32"

# ============================================
# FEATURE FLAGS
# ============================================
# Set to true to reactivate archived trip-planning features.
# Requires moving code back from src/_archive/ — flag alone does not revive archived routes.
# See src/_archive/README.md for revival steps.
ENABLE_TRIP_PLANNING=false
