// OutTheGroupchat - Unified Prisma Schema
// A collaborative travel planning app for groups

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  // Neon via Vercel Marketplace (migrated from Supabase 2026-04-17).
  // DATABASE_URL = pooler (pgbouncer=true) for runtime.
  // DIRECT_URL  = direct connection for migrations.
}

// ============================================
// AUTH MODELS (NextAuth.js)
// ============================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================
// USER MODEL
// ============================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  password      String?
  name          String?
  image         String?
  bio           String?
  city          String?
  crewLabel     String?   @db.VarChar(20) // User-customizable label for their crew (default "Crew")
  phone         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastActive    DateTime  @default(now())

  // Beta & Newsletter Fields
  betaSignupDate         DateTime?
  newsletterSubscribed   Boolean   @default(false)
  newsletterSubscribedAt DateTime?
  passwordInitialized    Boolean   @default(false)
  betaLaunchEmailSent    Boolean   @default(false)

  // User Preferences (stored as JSON for flexibility)
  preferences Json? // { travelStyle, interests, budgetRange, currency, language }

  // Auth Relations
  accounts Account[]
  sessions Session[]

  // Trip Relations
  ownedTrips      Trip[]           @relation("TripOwner")
  tripMemberships TripMember[]
  tripInvitations TripInvitation[]
  surveyResponses SurveyResponse[]

  // Social Relations
  followers Follow[] @relation("followers")
  following Follow[] @relation("following")

  // Activity Relations
  savedActivities  SavedActivity[]
  activityComments ActivityComment[]
  activityRatings  ActivityRating[]

  // Notifications
  notifications Notification[]

  // Pending invitations sent by this user
  sentPendingInvitations PendingInvitation[] @relation("InviterRelation")

  // Trip social engagement
  tripComments TripComment[]
  tripLikes    TripLike[]

  // Social domain relations (Phase 2)
  crewsAsA              Crew[]           @relation("CrewsAsA")
  crewsAsB              Crew[]           @relation("CrewsAsB")
  crewRequests          Crew[]           @relation("CrewRequests")
  hostedMeetups         Meetup[]         @relation("MeetupHost")
  meetupAttendances     MeetupAttendee[]
  meetupInvitesReceived MeetupInvite[]   @relation("MeetupInviteReceived")
  meetupInvitesSent     MeetupInvite[]   @relation("MeetupInviteSent")
  checkIns              CheckIn[]
  pollsCreated          Poll[]           @relation("PollCreator")
  pollResponses         PollResponse[]
  posts                 Post[]           @relation("PostAuthor")

  // V1 Intent-centric relations (Phase 0 — see docs/V1_IMPLEMENTATION_PLAN.md)
  intents                 Intent[]
  subCrewMemberships      SubCrewMember[]
  crewRelSettingsAsViewer CrewRelationshipSetting[] @relation("RelSettingViewer")
  crewRelSettingsAsTarget CrewRelationshipSetting[] @relation("RelSettingTarget")
  heatmapContributions    HeatmapContribution[]
  notificationPreferences NotificationPreference[]

  @@index([email])
  @@map("users")
}

// ============================================
// SOCIAL MODELS
// ============================================

/// @deprecated Scheduled for removal in Phase 8. Full Follow->Crew migration complete as of Phase 3.
model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("following", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("followers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  data      Json? // Additional context data
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

enum NotificationType {
  // Social domain notification types (Phase 2+)
  CREW_REQUEST
  CREW_ACCEPTED
  MEETUP_INVITED
  MEETUP_RSVP
  MEETUP_STARTING_SOON
  CHECK_IN_NEARBY
  CREW_CHECKED_IN_NEARBY
  SYSTEM
}

// ============================================
// TRIP SOCIAL ENGAGEMENT MODELS
// ============================================

// Comments on trip posts in the feed
model TripComment {
  id        String   @id @default(cuid())
  tripId    String
  userId    String
  text      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tripId])
  @@index([userId])
}

// Likes on trip posts in the feed
model TripLike {
  id        String   @id @default(cuid())
  tripId    String
  userId    String
  createdAt DateTime @default(now())

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tripId])
  @@index([tripId])
}

// ============================================
// TRIP MODELS
// ============================================

/// @deprecated Archived 2026-04-16 during social pivot (REFACTOR_PLAN.md Phase 1). Retained for potential future reactivation. See src/_archive/README.md.
model Trip {
  id          String     @id @default(cuid())
  title       String
  description String?
  status      TripStatus @default(PLANNING)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Destination Info (stored as JSON for flexibility)
  destination Json // { city, country, coordinates: {lat, lng}, timezone }

  // Date Range
  startDate DateTime
  endDate   DateTime

  // Budget Info
  budget Json? // { total, currency, breakdown: {accommodation, food, activities, transport} }

  // Owner
  ownerId String
  owner   User   @relation("TripOwner", fields: [ownerId], references: [id])

  // Group
  members     TripMember[]
  invitations TripInvitation[]

  // Survey & Voting
  survey         TripSurvey?
  votingSessions VotingSession[]

  // Content
  activities Activity[]
  itinerary  ItineraryDay[]

  // Cover Image (Unsplash URL)
  coverImage String?

  // Sharing Settings
  isPublic  Boolean @default(false)
  viewCount Int     @default(0)

  // Pending invitations for non-existent users
  pendingInvitations PendingInvitation[]

  // Social engagement (for feed interactions)
  comments TripComment[]
  likes    TripLike[]

  @@index([ownerId])
  @@index([status])
  @@index([startDate])
}

enum TripStatus {
  PLANNING
  INVITING
  SURVEYING
  VOTING
  BOOKED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

/// @deprecated Archived 2026-04-16 during social pivot (REFACTOR_PLAN.md Phase 1). Retained for potential future reactivation. See src/_archive/README.md.
model TripMember {
  id       String         @id @default(cuid())
  tripId   String
  userId   String
  role     TripMemberRole @default(MEMBER)
  joinedAt DateTime       @default(now())

  // Individual member settings
  budgetRange   Json? // { min, max, currency }
  departureCity String?
  flightDetails Json? // { estimatedCost, airline, confirmation }

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tripId, userId])
  @@index([tripId])
  @@index([userId])
}

enum TripMemberRole {
  OWNER
  ADMIN
  MEMBER
}

/// @deprecated Archived 2026-04-16 during social pivot (REFACTOR_PLAN.md Phase 1). Retained for potential future reactivation. See src/_archive/README.md.
model TripInvitation {
  id        String           @id @default(cuid())
  tripId    String
  userId    String
  status    InvitationStatus @default(PENDING)
  expiresAt DateTime
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tripId, userId])
  @@index([tripId])
  @@index([userId, status])
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

// Pending invitations for users who don't exist yet
// This prevents creating placeholder users which could be abused
/// @deprecated Archived 2026-04-16 during social pivot (REFACTOR_PLAN.md Phase 1). Retained for potential future reactivation. See src/_archive/README.md.
model PendingInvitation {
  id        String   @id @default(cuid())
  email     String
  tripId    String
  invitedBy String
  expiresAt DateTime
  createdAt DateTime @default(now())

  trip    Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  inviter User @relation("InviterRelation", fields: [invitedBy], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([tripId])
  @@index([expiresAt])
}

// ============================================
// SURVEY MODELS
// ============================================

/// @deprecated Archived 2026-04-16 during social pivot (REFACTOR_PLAN.md Phase 1). Retained for potential future reactivation. See src/_archive/README.md.
model TripSurvey {
  id        String       @id @default(cuid())
  tripId    String       @unique
  title     String
  status    SurveyStatus @default(DRAFT)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  expiresAt DateTime?

  // Survey configuration (questions, options)
  questions Json // Array of question objects

  trip      Trip             @relation(fields: [tripId], references: [id], onDelete: Cascade)
  responses SurveyResponse[]
}

enum SurveyStatus {
  DRAFT
  ACTIVE
  CLOSED
  ANALYZED
}

/// @deprecated Archived 2026-04-16 during social pivot (REFACTOR_PLAN.md Phase 1). Retained for potential future reactivation. See src/_archive/README.md.
model SurveyResponse {
  id        String   @id @default(cuid())
  surveyId  String
  userId    String
  answers   Json // { questionId: answer }
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  survey TripSurvey @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([surveyId, userId])
  @@index([surveyId])
}

// ============================================
// VOTING MODELS
// ============================================

/// @deprecated Archived 2026-04-16 during social pivot (REFACTOR_PLAN.md Phase 1). Retained for potential future reactivation. See src/_archive/README.md.
model VotingSession {
  id        String       @id @default(cuid())
  tripId    String
  type      VotingType
  status    VotingStatus @default(ACTIVE)
  title     String
  createdAt DateTime     @default(now())
  expiresAt DateTime

  // Voting options (destinations, activities, dates, etc.)
  options Json // Array of option objects

  trip  Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)
  votes Vote[]

  @@index([tripId])
}

enum VotingType {
  DESTINATION
  ACTIVITY
  DATE
  ACCOMMODATION
  CUSTOM
}

enum VotingStatus {
  ACTIVE
  CLOSED
  CANCELLED
}

/// @deprecated Archived 2026-04-16 during social pivot (REFACTOR_PLAN.md Phase 1). Retained for potential future reactivation. See src/_archive/README.md.
model Vote {
  id        String   @id @default(cuid())
  sessionId String
  orderId   String // Anonymous voting support (fixed typo from "oderId")
  optionId  String
  rank      Int? // For ranked voting
  createdAt DateTime @default(now())

  session VotingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, orderId, optionId])
  @@index([sessionId])
}

// ============================================
// ACTIVITY MODELS
// ============================================

/// @deprecated Archived 2026-04-16 during social pivot (REFACTOR_PLAN.md Phase 1). Retained for potential future reactivation. See src/_archive/README.md.
model Activity {
  id          String           @id @default(cuid())
  tripId      String
  name        String
  description String?
  category    ActivityCategory
  status      ActivityStatus   @default(SUGGESTED)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  // Location
  location Json? // { address, coordinates, placeId, nearestTransit }

  // Timing
  date      DateTime?
  startTime DateTime?
  endTime   DateTime?
  duration  Int? // in minutes

  // Cost
  cost        Float?
  currency    String      @default("USD")
  priceRange  PriceRange?
  costDetails Json? // { basePrice, includedItems, additionalCosts }

  // Booking
  bookingStatus    BookingStatus @default(NOT_NEEDED)
  bookingUrl       String?
  confirmationCode String?

  // Requirements
  requirements Json? // { minimumAge, physicalLevel, requiredItems, accessibility }

  // Social/Sharing
  isPublic       Boolean @default(false)
  originalTripId String? // If copied from another trip
  shareCount     Int     @default(0)

  // External Data
  externalLinks Json? // { websiteUrl, ticketmasterUrl, etc. }

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  // Engagement
  savedBy  SavedActivity[]
  comments ActivityComment[]
  ratings  ActivityRating[]

  // Itinerary
  itineraryItems ItineraryItem[]

  @@index([tripId])
  @@index([category])
  @@index([isPublic])
}

enum ActivityCategory {
  FOOD
  CULTURE
  SHOPPING
  NATURE
  ENTERTAINMENT
  SPORTS
  NIGHTLIFE
  TRANSPORTATION
  ACCOMMODATION
  OTHER
}

enum ActivityStatus {
  SUGGESTED
  APPROVED
  BOOKED
  COMPLETED
  CANCELLED
}

enum PriceRange {
  FREE
  BUDGET // $
  MODERATE // $$
  EXPENSIVE // $$$
  LUXURY // $$$$
}

enum BookingStatus {
  NOT_NEEDED
  RECOMMENDED
  REQUIRED
  BOOKED
  CONFIRMED
}

/// @deprecated Archived 2026-04-16 during social pivot (REFACTOR_PLAN.md Phase 1). Retained for potential future reactivation. See src/_archive/README.md.
model SavedActivity {
  id         String   @id @default(cuid())
  userId     String
  activityId String
  savedAt    DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@unique([userId, activityId])
  @@index([userId])
}

/// @deprecated Archived 2026-04-16 during social pivot (REFACTOR_PLAN.md Phase 1). Retained for potential future reactivation. See src/_archive/README.md.
model ActivityComment {
  id         String   @id @default(cuid())
  activityId String
  userId     String
  text       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([activityId])
}

/// @deprecated Archived 2026-04-16 during social pivot (REFACTOR_PLAN.md Phase 1). Retained for potential future reactivation. See src/_archive/README.md.
model ActivityRating {
  id         String   @id @default(cuid())
  activityId String
  userId     String
  score      Int // 1-5
  review     String?
  createdAt  DateTime @default(now())

  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([activityId, userId])
  @@index([activityId])
}

// ============================================
// ITINERARY MODELS
// ============================================

/// @deprecated Archived 2026-04-16 during social pivot (REFACTOR_PLAN.md Phase 1). Retained for potential future reactivation. See src/_archive/README.md.
model ItineraryDay {
  id        String   @id @default(cuid())
  tripId    String
  dayNumber Int
  date      DateTime
  notes     String?

  trip  Trip            @relation(fields: [tripId], references: [id], onDelete: Cascade)
  items ItineraryItem[]

  @@unique([tripId, dayNumber])
  @@index([tripId])
}

/// @deprecated Archived 2026-04-16 during social pivot (REFACTOR_PLAN.md Phase 1). Retained for potential future reactivation. See src/_archive/README.md.
model ItineraryItem {
  id             String  @id @default(cuid())
  itineraryDayId String
  activityId     String?
  order          Int
  startTime      String? // "09:00"
  endTime        String? // "12:00"
  customTitle    String? // For non-activity items
  notes          String?

  itineraryDay ItineraryDay @relation(fields: [itineraryDayId], references: [id], onDelete: Cascade)
  activity     Activity?    @relation(fields: [activityId], references: [id])

  @@index([itineraryDayId])
}

// ============================================
// EXTERNAL DATA MODELS (Open Source POIs)
// ============================================

/// @deprecated Archived 2026-04-16 during social pivot (REFACTOR_PLAN.md Phase 1). Retained for potential future reactivation. See src/_archive/README.md.
model ExternalActivity {
  id          String         @id @default(cuid())
  externalId  String // ID from source API (e.g., OpenTripMap xid)
  source      ExternalSource
  name        String
  description String?        @db.Text
  category    String // Food, Culture, Nightlife, etc.
  tags        String[] // For search/filtering

  // Location
  latitude  Float
  longitude Float
  address   String?
  city      String
  country   String

  // Metadata
  rating       Float?
  ratingCount  Int?
  priceLevel   Int? // 1-4 ($, $$, $$$, $$$$)
  imageUrl     String?
  thumbnailUrl String?
  websiteUrl   String?
  phoneNumber  String?
  openingHours Json? // Structured hours data

  // Search optimization
  searchText String? @db.Text // Combined searchable text
  popularity Int     @default(0) // For sorting/recommendations

  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lastFetched DateTime @default(now()) // When data was last synced

  @@unique([externalId, source])
  @@index([city, category])
  @@index([city, country])
  @@index([latitude, longitude])
}

enum ExternalSource {
  OPENTRIPMAP
  FOURSQUARE
  OPENSTREETMAP
  WIKIVOYAGE
  GOOGLE_PLACES
  YELP
  TRIPADVISOR
  MANUAL
}

// Cache for destination data
/// @deprecated Archived 2026-04-16 during social pivot (REFACTOR_PLAN.md Phase 1). Retained for potential future reactivation. See src/_archive/README.md.
model DestinationCache {
  id      String @id @default(cuid())
  city    String
  country String

  // Cached statistics
  activityCount Int      @default(0)
  averageRating Float?
  topCategories String[] // Most popular categories

  // Rich content
  description     String? @db.Text
  highlights      Json? // Key attractions
  bestTimeToVisit String?
  averageBudget   Json? // { low, mid, high }

  // Metadata
  lastUpdated DateTime @default(now())
  dataQuality Int      @default(0) // 0-100 score

  @@unique([city, country])
  @@index([country])
}

// ============================================
// SOCIAL DOMAIN ENUMS (Phase 2 — 2026-04-17)
// ============================================

enum CrewStatus {
  PENDING
  ACCEPTED
  DECLINED
  BLOCKED
}

enum MeetupVisibility {
  PUBLIC
  CREW
  INVITE_ONLY
  PRIVATE
}

enum AttendeeStatus {
  GOING
  MAYBE
  DECLINED
}

enum InviteStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

enum VenueCategory {
  BAR
  COFFEE
  RESTAURANT
  PARK
  GYM
  COWORKING
  OTHER
}

enum CheckInVisibility {
  PUBLIC
  CREW
  PRIVATE
}

enum PollType {
  SURVEY
  VOTE
  RSVP_POLL
}

enum PostType {
  CHECK_IN
  MEETUP_CREATED
  MEETUP_ATTENDED
  CREW_MADE
  TEXT_POST
}

// ============================================
// SOCIAL DOMAIN MODELS (Phase 2 — 2026-04-17)
// ============================================

model City {
  id        String   @id @default(cuid())
  name      String
  state     String?
  country   String
  timezone  String?
  latitude  Float
  longitude Float
  createdAt DateTime @default(now())

  venues   Venue[]
  meetups  Meetup[]
  checkIns CheckIn[]

  @@unique([name, country])
  @@index([country])
}

model Venue {
  id         String        @id @default(cuid())
  name       String
  address    String?
  city       String
  country    String
  latitude   Float?
  longitude  Float?
  category   VenueCategory @default(OTHER)
  source     String? // "google_places", "manual", etc.
  externalId String? // ID from source API
  imageUrl   String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  cityRef City?   @relation(fields: [cityId], references: [id])
  cityId  String?

  meetups  Meetup[]
  checkIns CheckIn[]
  intents  Intent[]

  @@index([city, category])
  @@index([latitude, longitude])
}

model Crew {
  id            String     @id @default(cuid())
  userAId       String
  userBId       String
  status        CrewStatus @default(PENDING)
  requestedById String
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  userA       User @relation("CrewsAsA", fields: [userAId], references: [id], onDelete: Cascade)
  userB       User @relation("CrewsAsB", fields: [userBId], references: [id], onDelete: Cascade)
  requestedBy User @relation("CrewRequests", fields: [requestedById], references: [id])

  @@unique([userAId, userBId])
  @@index([userAId, status])
  @@index([userBId, status])
  @@index([requestedById])
}

model Meetup {
  id          String           @id @default(cuid())
  title       String
  description String?
  hostId      String
  venueId     String?
  venueName   String?
  cityId      String?
  scheduledAt DateTime
  endsAt      DateTime?
  visibility  MeetupVisibility @default(CREW)
  capacity    Int?
  cancelled   Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  host  User   @relation("MeetupHost", fields: [hostId], references: [id], onDelete: Cascade)
  venue Venue? @relation(fields: [venueId], references: [id])
  city  City?  @relation(fields: [cityId], references: [id])

  attendees MeetupAttendee[]
  invites   MeetupInvite[]
  polls     Poll[]
  subCrew   SubCrew? // back-relation; set when a SubCrew coordinates into this Meetup

  @@index([hostId])
  @@index([scheduledAt])
  @@index([cityId, scheduledAt])
}

model MeetupAttendee {
  id          String         @id @default(cuid())
  meetupId    String
  userId      String
  status      AttendeeStatus @default(GOING)
  checkedInAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  meetup Meetup @relation(fields: [meetupId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([meetupId, userId])
  @@index([meetupId])
  @@index([userId])
}

model MeetupInvite {
  id        String       @id @default(cuid())
  meetupId  String
  userId    String
  invitedBy String
  status    InviteStatus @default(PENDING)
  expiresAt DateTime?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  meetup  Meetup @relation(fields: [meetupId], references: [id], onDelete: Cascade)
  user    User   @relation("MeetupInviteReceived", fields: [userId], references: [id], onDelete: Cascade)
  inviter User   @relation("MeetupInviteSent", fields: [invitedBy], references: [id])

  @@unique([meetupId, userId])
  @@index([meetupId])
  @@index([userId, status])
}

model CheckIn {
  id          String            @id @default(cuid())
  userId      String
  venueId     String?
  venueName   String?
  cityId      String?
  note        String?
  visibility  CheckInVisibility @default(CREW)
  activeUntil DateTime          @default(dbgenerated("(now() + interval '6 hours')"))
  latitude    Float?
  longitude   Float?
  createdAt   DateTime          @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  venue Venue? @relation(fields: [venueId], references: [id])
  city  City?  @relation(fields: [cityId], references: [id])

  @@index([userId])
  @@index([cityId, createdAt])
  @@index([createdAt])
  @@index([activeUntil])
}

model Poll {
  id        String    @id @default(cuid())
  title     String
  type      PollType
  options   Json // Array of { id: cuid, text: string }
  meetupId  String?
  createdBy String
  expiresAt DateTime?
  closed    Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  meetup    Meetup?        @relation(fields: [meetupId], references: [id], onDelete: SetNull)
  creator   User           @relation("PollCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  responses PollResponse[]

  @@index([meetupId])
  @@index([createdBy])
  @@index([expiresAt])
}

model PollResponse {
  id        String   @id @default(cuid())
  pollId    String
  userId    String
  answers   Json // { optionIds: string[] }
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  poll Poll @relation(fields: [pollId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([pollId, userId])
  @@index([pollId])
}

model Post {
  id        String   @id @default(cuid())
  authorId  String
  type      PostType
  content   String?
  data      Json? // type-specific payload (checkInId, meetupId, connectionId, etc.)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author User @relation("PostAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([authorId, createdAt])
  @@index([createdAt])
}

// ============================================
// V1 INTENT-CENTRIC MODELS
// ============================================
// Source: docs/PRODUCT_VISION.md (R1–R25) + docs/V1_IMPLEMENTATION_PLAN.md Phase 0.
// All field choices trace to a numbered resolution; comments cite the relevant R#.

enum WindowPreset {
  EARLY_MORNING
  MORNING
  BRUNCH
  AFTERNOON
  EVENING
  NIGHT
}

enum IntentState {
  INTERESTED // initial signal — visible to Crew, no heatmap contribution (R6)
  COMMITTED // post-alignment — picks 3-axis privacy, contributes per R5/R20
}

enum SubCrewJoinMode {
  SEED // one of the original 2 that formed the SubCrew (R2)
  JOINED_VIA_IM_IN // tapped "I'm in" after formation (R21)
}

enum HeatmapContributionType {
  INTEREST // from a live INTERESTED Intent (R13)
  PRESENCE // from a CheckIn after COMMITTED + arrival (R13)
}

enum HeatmapGranularityMode {
  BLOCK // baseline (R4)
  DYNAMIC_CELL // finer; per-relationship opt-in (R4)
  HIDDEN // explicit block-listed
}

enum HeatmapIdentityMode {
  KNOWN // attributed (R20 Crew default)
  ANONYMOUS // unattributed (subject to N≥3 floor per R14)
  CREW_ANCHORED // FoF: "anonymous friend of [X]" (R20)
}

enum HeatmapSocialScope {
  FULL_CREW
  SUBGROUP_ONLY
  NOBODY // default per R4
}

enum NotificationPreferenceTrigger {
  DAILY_PROMPT // morning push, R8
  PER_MEMBER_INTENT // user-flagged Crew member signaled, R8
  GROUP_FORMATION // automatic; toggle controls whether the user gets push for it
}

/// Curated taxonomy backing free-text bucketing per R1/R9.
/// `keywords` is the deterministic dictionary v1 uses to classify Intent.rawText
/// into a Topic. `placesCategories` per R15 — maps to Google Places taxonomy.
model Topic {
  id               String   @id @default(cuid())
  slug             String   @unique
  displayName      String
  keywords         String[]
  placesCategories String[]
  createdAt        DateTime @default(now())

  intents  Intent[]
  subCrews SubCrew[]
}

/// Lightweight signal of "what I want to do." Lighter than a Meetup — no fixed
/// time, no attendees, no commitment until COMMITTED. See R3, R6, R12, R16, R22.
model Intent {
  id           String       @id @default(cuid())
  userId       String
  topicId      String
  windowPreset WindowPreset
  startAt      DateTime? // override of preset default (R3)
  endAt        DateTime? // override of preset default (R3)
  dayOffset    Int          @default(0) // 0..7 lookahead (R3)
  state        IntentState  @default(INTERESTED)
  cityArea     String? // neighborhood slug per R16
  venueId      String? // specific-venue override per R22
  rawText      String? // original user input (audit + future v1.5 embedder training)
  createdAt    DateTime     @default(now())
  expiresAt    DateTime // = window end + 2h per R12

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic Topic  @relation(fields: [topicId], references: [id])
  venue Venue? @relation(fields: [venueId], references: [id])

  subCrewMemberships SubCrewMember[]

  @@index([userId, state, expiresAt]) // "my live intents"
  @@index([topicId, windowPreset, dayOffset, expiresAt]) // SubCrew formation scan
  @@index([cityArea]) // Interest heatmap aggregation
}

/// Auto-formed when ≥2 Crew members hold matching live INTERESTED Intents (R2).
/// Adjacent-window hedges collapse to one SubCrew (R17). Optionally links to a
/// concrete Meetup once coordination converges on time + venue.
model SubCrew {
  id           String       @id @default(cuid())
  topicId      String
  windowPreset WindowPreset
  startAt      DateTime // broadest of the seed Intents' windows
  endAt        DateTime
  cityArea     String?
  venueId      String?
  meetupId     String?      @unique // set once SubCrew coordinates into a Meetup
  createdAt    DateTime     @default(now())

  topic   Topic           @relation(fields: [topicId], references: [id])
  meetup  Meetup?         @relation(fields: [meetupId], references: [id])
  members SubCrewMember[]

  @@index([topicId, windowPreset, startAt])
}

model SubCrewMember {
  id        String          @id @default(cuid())
  subCrewId String
  userId    String
  intentId  String? // what opted them in (null if joined-without-Intent edge case)
  joinedAt  DateTime        @default(now())
  joinMode  SubCrewJoinMode

  subCrew SubCrew @relation(fields: [subCrewId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  intent  Intent? @relation(fields: [intentId], references: [id])

  @@unique([subCrewId, userId])
  @@index([userId])
}

/// Per-relationship privacy overrides (R4 Axis 2 + 3). Defaults: BLOCK + KNOWN
/// for direct Crew (R20); FoF defaults computed in app code, not stored here.
model CrewRelationshipSetting {
  id              String                 @id @default(cuid())
  viewerId        String
  targetId        String
  granularityMode HeatmapGranularityMode @default(BLOCK)
  identityMode    HeatmapIdentityMode    @default(KNOWN)
  updatedAt       DateTime               @updatedAt
  createdAt       DateTime               @default(now())

  viewer User @relation("RelSettingViewer", fields: [viewerId], references: [id], onDelete: Cascade)
  target User @relation("RelSettingTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([viewerId, targetId])
  @@index([targetId])
}

/// Derived data fed by Intents (INTEREST type) and CheckIns (PRESENCE type).
/// Cell coordinates already anonymized at write time; raw lat/lng never leaves
/// the aggregation window. See R13 for the two-window heatmap model.
model HeatmapContribution {
  id            String                  @id @default(cuid())
  userId        String
  type          HeatmapContributionType
  sourceId      String // Intent.id or CheckIn.id depending on type
  cellLat       Float // anonymized cell center
  cellLng       Float
  cellPrecision HeatmapGranularityMode
  topicId       String?
  windowPreset  WindowPreset?
  socialScope   HeatmapSocialScope
  identityMode  HeatmapIdentityMode
  expiresAt     DateTime
  createdAt     DateTime                @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([type, expiresAt, topicId]) // heatmap reads
  @@index([userId, expiresAt]) // cleanup + user-scoped queries
}

/// Per-trigger notification opt-ins (R8). Daily prompt + per-member triggers
/// + group-formation default-on. perMemberTargets is a denormalized list of
/// userIds the viewer has flagged for PER_MEMBER_INTENT.
model NotificationPreference {
  id               String                        @id @default(cuid())
  userId           String
  trigger          NotificationPreferenceTrigger
  enabled          Boolean                       @default(false)
  schedule         String? // e.g. "09:00" for DAILY_PROMPT
  perMemberTargets String[] // populated when trigger = PER_MEMBER_INTENT
  updatedAt        DateTime                      @updatedAt
  createdAt        DateTime                      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, trigger])
}
